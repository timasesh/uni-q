# Локальная разработка (скопируйте в .env при необходимости)
NODE_ENV=development
PORT=5174
WEB_ORIGIN=http://localhost:5173
SESSION_SECRET=замените-на-длинную-случайную-строку
# Файл локальной БД (все талоны, история, отзывы). По умолчанию — ./data/uni-q.sqlite в папке проекта.
# SQLITE_PATH=C:\Users\Вы\Documents\uni-q-backup.sqlite
SQLITE_PATH=./data/uni-q.sqlite

# Production (Render): задайте WEB_ORIGIN = точный URL фронта, например https://uni-q.onrender.com
# TRUST_PROXY=1
# SESSION_COOKIE_SECURE=0   # только если отлаживаете HTTPS за нестандартным прокси

# --- Supabase PostgreSQL (схема: supabase/migrations/*.sql) ---
# Очередь и талоны остаются в SQLite. Если задать DATABASE_URL, таблица ticket_visit_log дублируется в Postgres,
# а история в админке и у эдвайзера читается из облака (Supabase → Table Editor / SQL).
# На Render используйте Session pooler (порт 6543, *.pooler.supabase.com), не direct db.*:5432 — иначе часто IPv6 ENETUNREACH.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# DATABASE_DNS_IPV4_FIRST=0   # отключить приоритет IPv4 в DNS (редко)
# UNIQ_REPORT_TZ=UTC          # таймзона для фильтра дат по finished_at (по умолчанию UTC)
# DATABASE_SSL=0            # только если провайдер требует без SSL (Supabase обычно нужен SSL = по умолчанию)
